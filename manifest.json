{
  "manifest_version": 3,
  "name": "FoxVox Extended",
  "version": "4.0",
  "description": "Rewrite any webpage with different perspectives, or fact-check it with multiple AI models side-by-side.",
  "permissions": ["storage", "tabs", "webNavigation", "scripting", "activeTab"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "dist/background.bundle.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["config.json"],
      "matches": ["<all_urls>"],
      "extension_ids": ["*"]
    }
  ]
}
